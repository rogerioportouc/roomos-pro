{
  "$$schema": "https://easypanel.io/schema/app.json",
  "name": "roomos-pro",
  "displayName": "RoomOS Pro",
  "description": "Sistema de Reserva de Salas de Reunião — EasyPanel Deployment",
  "version": "2.4.1",

  "services": [
    {
      "name": "app",
      "type": "app",
      "source": {
        "type": "github",
        "repo": "SEU_USUARIO/roomos-pro",
        "ref": "main",
        "autoDeploy": true
      },
      "build": {
        "type": "dockerfile",
        "file": "docker/Dockerfile"
      },
      "env": [
        "NODE_ENV=production",
        "PORT=3000",
        "DATABASE_URL=postgresql://roomos:${POSTGRES_PASSWORD}@roomos-pro_db:5432/roomos",
        "REDIS_HOST=roomos-pro_redis",
        "REDIS_PORT=6379",
        "REDIS_PASSWORD=${REDIS_PASSWORD}",
        "JWT_SECRET=${JWT_SECRET}",
        "JWT_EXPIRES=24h",
        "REFRESH_SECRET=${REFRESH_SECRET}",
        "APP_URL=https://${EASYPANEL_DOMAIN}",
        "APP_NAME=${APP_NAME}",
        "GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}",
        "GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET}",
        "MS_CLIENT_ID=${MS_CLIENT_ID}",
        "MS_CLIENT_SECRET=${MS_CLIENT_SECRET}",
        "MS_TENANT_ID=${MS_TENANT_ID}",
        "SMTP_HOST=${SMTP_HOST}",
        "SMTP_PORT=${SMTP_PORT}",
        "SMTP_USER=${SMTP_USER}",
        "SMTP_PASS=${SMTP_PASS}",
        "TZ=America/Sao_Paulo"
      ],
      "ports": [
        { "published": 3000, "target": 3000, "protocol": "tcp" }
      ],
      "volumes": [
        { "type": "volume", "name": "uploads", "mountPath": "/app/uploads" }
      ],
      "domains": [
        { "host": "$(EASYPANEL_DOMAIN)", "port": 3000 }
      ],
      "deploy": {
        "replicas": 1,
        "command": "node dist/server.js"
      },
      "healthCheck": {
        "path": "/health",
        "interval": 30,
        "timeout": 10,
        "retries": 3
      }
    },
    {
      "name": "db",
      "type": "postgres",
      "image": "postgres:15-alpine",
      "data": {
        "database": "roomos",
        "user": "roomos",
        "password": "${POSTGRES_PASSWORD}"
      },
      "volumes": [
        { "type": "volume", "name": "pgdata", "mountPath": "/var/lib/postgresql/data" }
      ]
    },
    {
      "name": "redis",
      "type": "redis",
      "image": "redis:7-alpine",
      "data": {
        "password": "${REDIS_PASSWORD}"
      },
      "command": "redis-server --requirepass ${REDIS_PASSWORD} --maxmemory 256mb --maxmemory-policy allkeys-lru",
      "volumes": [
        { "type": "volume", "name": "redis-data", "mountPath": "/data" }
      ]
    }
  ]
}
