# ============================================================
#  RoomOS Pro — Variáveis de Ambiente
#  Copie para .env e preencha os valores
#  cp .env.example .env
# ============================================================

# ── Aplicação ───────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_NAME=RoomOS
APP_URL=https://salas.suaempresa.com.br
TZ=America/Sao_Paulo

# ── Banco de dados PostgreSQL ────────────────────────────────
# EasyPanel: use o hostname do serviço (ex: roomos-pro_db)
DATABASE_URL=postgresql://roomos:SENHA_AQUI@localhost:5432/roomos
POSTGRES_PASSWORD=SENHA_FORTE_AQUI

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=SENHA_REDIS_AQUI

# ── JWT / Segurança ──────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=GERE_UMA_CHAVE_AQUI
JWT_EXPIRES=24h
REFRESH_SECRET=GERE_OUTRA_CHAVE_AQUI

# ── SSO Google Workspace (opcional) ─────────────────────────
# https://console.cloud.google.com → Credenciais → OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback: https://APP_URL/api/auth/google/callback

# ── SSO Microsoft 365 / Azure AD (opcional) ─────────────────
# https://portal.azure.com → Azure AD → Registros de aplicativo
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
# Callback: https://APP_URL/api/auth/microsoft/callback

# ── E-mail SMTP (opcional) ───────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@suaempresa.com.br

# ── EasyPanel / Deploy ───────────────────────────────────────
# Configurado automaticamente pelo EasyPanel
# EASYPANEL_DOMAIN=salas.suaempresa.com.br
